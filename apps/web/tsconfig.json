{
    "extends":  "../../tsconfig.base.json",
    "compilerOptions":  {
                            "jsx":  "react-jsx",
                            "types":  [
                                          "vite/client"
                                      ],
                            "lib":  [
                                        "ES2022",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "noEmit":  true,
                            "allowImportingTsExtensions":  false
                        },
    "include":  [
                    "src/**/*.ts",
                    "src/**/*.tsx",
                    "vite.config.ts"
                ],
    "references":  [
                       {
                           "path":  "../../packages/api-contracts"
                       }
                   ]
}