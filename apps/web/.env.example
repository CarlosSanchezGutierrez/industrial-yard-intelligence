# Aplomo Systems
# Variables publicas para la app web.
# Copiar este archivo como .env.local cuando ya exista proyecto Supabase real.

# URL publica del proyecto Supabase.
VITE_SUPABASE_URL=

# Llave anon publica de Supabase.
# Esta llave puede estar en frontend porque Supabase la protege con RLS.
VITE_SUPABASE_ANON_KEY=

# No poner aqui SUPABASE_SERVICE_ROLE_KEY.
# La service role key nunca debe vivir en frontend.
