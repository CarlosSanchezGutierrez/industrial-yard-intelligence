{
  "name": "@iyi/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Database schema conventions and migration primitives for Industrial Yard Intelligence.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "@iyi/kernel": "workspace:*",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8"
  }
}