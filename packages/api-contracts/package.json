{
  "name": "@iyi/api-contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared API request and response contracts for Industrial Yard Intelligence.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
